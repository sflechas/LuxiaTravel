---
import Layout from '../components/Layout.astro';
---
<Layout title="Luxia Travel – Effortless luxury" description="Curated escapes that make it easy to unwind with style.">
  <section class="hero">
    <div class="container">
      <h1>Unwind with style.</h1>
      <p>Curated, minimalist, editorial travel experiences across handpicked destinations.</p>
      <a class="cta" href="/contact/">Start an inquiry</a>
    </div>
  </section>

  <section style="margin-top:24px">
    <h2>Featured Destinations</h2>
    <div class="grid">
      <div class="card"><strong>Tulum</strong><br/><span class="muted">Warm sands, calm design, modern villas.</span></div>
      <div class="card"><strong>Lisbon</strong><br/><span class="muted">Light, tile, viewpoints, and boutique stays.</span></div>
      <div class="card"><strong>Amalfi</strong><br/><span class="muted">Cliffside elegance and effortless dining.</span></div>
    </div>
  </section>
</Layout>
